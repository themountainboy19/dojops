DOJOPS_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# Ollama: No API key needed. Requires server at localhost:11434 by default.
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_TLS_REJECT_UNAUTHORIZED=true

# GitHub Copilot: Uses OAuth Device Flow. Run `dojops auth login --provider github-copilot`.
# GITHUB_COPILOT_TOKEN=ghu_xxx   # Optional: pre-set GitHub OAuth token (skips device flow)

# Optional overrides (sensible defaults apply):
# DOJOPS_MODEL=
# DOJOPS_TEMPERATURE=
# DOJOPS_API_PORT=3000

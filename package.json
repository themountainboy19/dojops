{
  "name": "oda",
  "private": true,
  "description": "ODA — AI-powered DevOps automation agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oda-devops/oda.git"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "oda": "packages/cli/dist/index.js"
  },
  "scripts": {
    "oda": "node packages/cli/dist/index.js",
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "publish-packages": "pnpm build && pnpm -r publish --access public"
  },
  "lint-staged": {
    "*.{ts,mjs,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}

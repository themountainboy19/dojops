{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@dojops/core/*": ["packages/core/src/*"],
      "@dojops/sdk/*": ["packages/sdk/src/*"],
      "@dojops/planner/*": ["packages/planner/src/*"],
      "@dojops/executor/*": ["packages/executor/src/*"],
      "@dojops/api/*": ["packages/api/src/*"],
      "@dojops/scanner/*": ["packages/scanner/src/*"],
      "@dojops/session/*": ["packages/session/src/*"],
      "@dojops/skill-registry/*": ["packages/skill-registry/src/*"],
      "@dojops/runtime/*": ["packages/runtime/src/*"],
      "@dojops/context/*": ["packages/context/src/*"]
    }
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@oda/core/*": ["packages/core/src/*"],
      "@oda/sdk/*": ["packages/sdk/src/*"],
      "@oda/planner/*": ["packages/planner/src/*"],
      "@oda/tools/*": ["packages/tools/src/*"]
    }
  }
}

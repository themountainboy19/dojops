{
  "name": "@dojops/core",
  "version": "1.0.0",
  "description": "LLM providers, multi-agent routing, CI debugger, and infra diff analysis for DojOps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/core"
  },
  "keywords": [
    "devops",
    "llm",
    "openai",
    "anthropic",
    "ollama",
    "agent",
    "ci-debugger",
    "infra-diff"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "node -e \"if(JSON.stringify(require('./package.json')).includes('workspace:'))process.exit(1)\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@google/genai": "^1.42.0",
    "axios": "^1.6.0",
    "openai": "^4.0.0",
    "zod": "^3.23.0"
  }
}

{
  "name": "@dojops/session",
  "version": "1.0.6",
  "description": "Interactive AI chat session management for DojOps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/session"
  },
  "keywords": [
    "devops",
    "chat",
    "session",
    "ai",
    "multi-turn"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "zod": "^4.0.0"
  }
}

{
  "name": "@dojops/cli",
  "version": "1.0.0",
  "description": "CLI for DojOps — AI DevOps Automation Engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "devops",
    "cli",
    "ai",
    "automation",
    "terraform",
    "kubernetes",
    "github-actions",
    "infrastructure-as-code"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "dojops": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@dojops/api": "workspace:*",
    "@dojops/core": "workspace:*",
    "@dojops/executor": "workspace:*",
    "@dojops/planner": "workspace:*",
    "@dojops/scanner": "workspace:*",
    "@dojops/session": "workspace:*",
    "@dojops/tool-registry": "workspace:*",
    "@dojops/tools": "workspace:*",
    "dotenv": "^16.0.0",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}

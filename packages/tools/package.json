{
  "name": "@dojops/tools",
  "version": "1.0.0",
  "description": "DevOps tools for GitHub Actions, Terraform, Kubernetes, Helm, and Ansible",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/tools"
  },
  "keywords": [
    "devops",
    "github-actions",
    "terraform",
    "kubernetes",
    "helm",
    "ansible",
    "infrastructure-as-code"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -d dist"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "zod": "^3.23.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}

{
  "name": "@dojops/skill-registry",
  "version": "1.1.0",
  "description": "Skill registry for DojOps — discovers, loads, and manages built-in and custom skills",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/skill-registry"
  },
  "keywords": [
    "devops",
    "skills",
    "dops",
    "registry"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/runtime": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}

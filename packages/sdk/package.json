{
  "name": "@dojops/sdk",
  "version": "1.0.0",
  "description": "Base tool abstraction and Zod validation for DojOps DevOps agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "devops",
    "sdk",
    "tools",
    "zod",
    "validation"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -d dist"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}

{
  "name": "@dojops/scanner",
  "version": "1.0.5",
  "description": "Security scanning engine for DojOps — vulnerability, dependency, IaC, and secret scanning",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/scanner"
  },
  "keywords": [
    "devops",
    "security",
    "scanning",
    "vulnerability",
    "dependency-audit",
    "iac",
    "secrets"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "zod": "^4.0.0"
  }
}

{
  "name": "@odaops/api",
  "version": "1.0.0",
  "description": "REST API server and web dashboard for ODA DevOps agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oda-devops/oda.git",
    "directory": "packages/api"
  },
  "keywords": [
    "devops",
    "api",
    "rest",
    "dashboard",
    "express"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --require dotenv/config dist/server.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts"
  },
  "dependencies": {
    "@odaops/core": "workspace:*",
    "@odaops/sdk": "workspace:*",
    "@odaops/planner": "workspace:*",
    "@odaops/tools": "workspace:*",
    "@odaops/executor": "workspace:*",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}

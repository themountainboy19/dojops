{
  "name": "@dojops/api",
  "version": "1.0.2",
  "description": "REST API server and web dashboard for DojOps DevOps agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/api"
  },
  "keywords": [
    "devops",
    "api",
    "rest",
    "dashboard",
    "express"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "node --require dotenv/config dist/server.js",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "prepublishOnly": "test -f dist/index.js && test -f dist/index.d.ts"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/executor": "workspace:*",
    "@dojops/planner": "workspace:*",
    "@dojops/scanner": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "@dojops/session": "workspace:*",
    "@dojops/tool-registry": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0"
  }
}

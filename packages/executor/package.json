{
  "name": "@dojops/executor",
  "version": "1.0.0",
  "description": "Sandboxed execution engine with policy controls and approval workflows for DojOps",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/executor"
  },
  "keywords": [
    "devops",
    "executor",
    "sandbox",
    "policy",
    "approval"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "node -e \"if(JSON.stringify(require('./package.json')).includes('workspace:'))process.exit(1)\""
  },
  "dependencies": {
    "@dojops/sdk": "workspace:*",
    "zod": "^3.23.0"
  }
}

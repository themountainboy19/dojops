{
  "name": "@dojops/tool-registry",
  "version": "1.0.0",
  "description": "Tool registry with plugin system for DojOps — discovers, loads, and manages built-in and plugin tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dojops/dojops.git",
    "directory": "packages/tool-registry"
  },
  "keywords": [
    "devops",
    "tools",
    "plugins",
    "registry"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "test": "vitest run",
    "prepublishOnly": "test -d dist"
  },
  "dependencies": {
    "@dojops/core": "workspace:*",
    "@dojops/sdk": "workspace:*",
    "@dojops/tools": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9"
  }
}
